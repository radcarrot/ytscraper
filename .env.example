# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Required for discover/full modes. Get one at:
#   https://console.cloud.google.com  ->  enable "YouTube Data API v3"  ->  Credentials -> API key
YOUTUBE_API_KEY=

# Optional. Residential proxy for the download/API legs (§7.3). Leave blank to go direct.
# Format: http://user:pass@host:port
DATASET_PROXY=

# Optional but the single biggest anti-bot win for the download leg (§7.7).
# EITHER point to an exported Netscape cookies.txt from a logged-in (throwaway)
# YouTube account:
YOUTUBE_COOKIES=
# OR pull cookies live from an installed browser profile (chrome|firefox|edge|brave):
YOUTUBE_COOKIES_FROM_BROWSER=
